{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": ["ES2022"],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "sourceMap": true
    },
    "exclude": ["node_modules", "out", "packages"],
    "references": [
        { "path": "packages/language-server" },
        { "path": "packages/vscode-extension" }
    ]
}
