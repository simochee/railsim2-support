{
  "name": "railsim2-support",
  "displayName": "RailSim2 Support",
  "version": "0.1.0",
  "description": "RailSim2 プラグイン定義ファイルの開発支援",
  "categories": [
    "Programming Languages"
  ],
  "homepage": "https://github.com/simochee/railsim2-support",
  "bugs": {
    "url": "https://github.com/simochee/railsim2-support/issues",
    "email": "lollipop@simochee.net"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/simochee/railsim2-support.git"
  },
  "publisher": "simochee",
  "main": "./out/extension.js",
  "browser": "./out/extension.browser.js",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "vitest run",
    "generate:grammar": "tsx scripts/generateGrammar.ts",
    "prepackage": "cp ../../THIRD_PARTY_LICENSES ./THIRD_PARTY_LICENSES",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "@railsim2-support/language-server": "workspace:*",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0",
    "vitest": "^4.1.2",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "railsim2",
        "aliases": [
          "RailSim2",
          "railsim2",
          "rs2"
        ],
        "filenames": [
          "Rail2.txt",
          "Tie2.txt",
          "Girder2.txt",
          "Pier2.txt",
          "Line2.txt",
          "Pole2.txt",
          "Train2.txt",
          "Station2.txt",
          "Struct2.txt",
          "Surface2.txt",
          "Env2.txt",
          "Skin2.txt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "railsim2",
        "scopeName": "source.rs2",
        "path": "./syntaxes/railsim2.tmLanguage.json"
      }
    ]
  },
  "activationEvents": [],
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "capabilities": {
    "virtualWorkspaces": true
  }
}
