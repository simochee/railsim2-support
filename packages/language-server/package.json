{
  "name": "@railsim2-support/language-server",
  "version": "0.1.0",
  "description": "Language Server for RailSim2 plugin definition files",
  "license": "MIT",
  "bin": {
    "railsim2-support-language-server": "./bin/railsim2-language-server.cjs"
  },
  "files": [
    "out",
    "bin"
  ],
  "exports": {
    "./node": "./out/server/connection.node.js",
    "./browser": "./out/server/connection.browser.js",
    "./keywords": "./out/shared/keywords.js",
    "./schema": "./out/schema/semantic.generated.js",
    "./formatter": "./out/server/formatter.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "generate": "tsx scripts/extract-hover-data.ts"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "cheerio": "^1.2.0",
    "iconv-lite": "^0.7.2",
    "vitest": "^4.1.2"
  }
}
