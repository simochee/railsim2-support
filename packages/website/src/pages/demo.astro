---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { parse as parseJsonc } from "jsonc-parser";
import Banner from "../components/Banner.astro";
import { DemoEditor } from "../components/DemoEditor";
import { getSamples } from "../lib/samples";

const samples = getSamples();

const REPO_ROOT = resolve(process.cwd(), "../..");

const grammarPath = resolve(
  REPO_ROOT,
  "packages/vscode-extension/syntaxes/railsim2.tmLanguage.json",
);
const grammar = JSON.parse(readFileSync(grammarPath, "utf-8"));

const langConfPath = resolve(
  REPO_ROOT,
  "packages/vscode-extension/language-configuration.json",
);
const langConf = parseJsonc(readFileSync(langConfPath, "utf-8"));
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>Live Demo - RailSim2 Support</title>
    <style is:global>
      body {
        margin: 0;
        background: #1e1e1e;
        color: #e0e0e0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      }
      .demo-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px;
      }
      .demo-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
      }
      .demo-header label {
        font-size: 14px;
        color: #ccc;
      }
      .demo-header select {
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid #555;
        background: #2d2d2d;
        color: #e0e0e0;
        font-size: 14px;
      }
      .demo-select-sm {
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid #555;
        background: #2d2d2d;
        color: #e0e0e0;
        font-size: 13px;
      }
      .demo-btn {
        padding: 4px 12px;
        border-radius: 4px;
        border: 1px solid #555;
        background: #2d2d2d;
        color: #e0e0e0;
        font-size: 14px;
        cursor: pointer;
        transition: background 0.15s;
      }
      .demo-btn:hover {
        background: #3d3d3d;
      }
      .demo-separator {
        width: 1px;
        height: 20px;
        background: #555;
        flex-shrink: 0;
      }
      .editor-wrapper {
        height: calc(100vh - 140px);
        border: 1px solid #333;
        border-radius: 4px;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <Banner />
    <div class="demo-container">
      <DemoEditor client:only="react" samples={samples} grammar={grammar} langConf={langConf} />
    </div>
  </body>
</html>
