---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { parse as parseJsonc } from "jsonc-parser";
import Banner from "../components/Banner.astro";
import { DemoEditor } from "../components/DemoEditor";
import { getSamples } from "../lib/samples";

const samples = getSamples();

const REPO_ROOT = resolve(process.cwd(), "../..");

const grammarPath = resolve(
  REPO_ROOT,
  "packages/vscode-extension/syntaxes/railsim2.tmLanguage.json",
);
const grammar = JSON.parse(readFileSync(grammarPath, "utf-8"));

const langConfPath = resolve(
  REPO_ROOT,
  "packages/vscode-extension/language-configuration.json",
);
const langConf = parseJsonc(readFileSync(langConfPath, "utf-8"));
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>Live Demo - RailSim2 Support</title>
    <style is:global>
      body {
        margin: 0;
        background: #1e1e1e;
        color: #e0e0e0;
      }
      .demo-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 16px;
      }
    </style>
  </head>
  <body>
    <Banner />
    <div class="demo-container">
      <DemoEditor client:only="react" samples={samples} grammar={grammar} langConf={langConf} />
    </div>
  </body>
</html>
