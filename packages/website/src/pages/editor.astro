---
import { readFileSync } from "node:fs";
import { resolve } from "node:path";
import { parse as parseJsonc } from "jsonc-parser";
import EditorBanner from "../components/EditorBanner.astro";
import { OnlineEditor } from "../components/Editor";
import { getSamples } from "../lib/samples";

const samples = getSamples();

const REPO_ROOT = resolve(process.cwd(), "../..");

const grammarPath = resolve(
  REPO_ROOT,
  "packages/vscode-extension/syntaxes/railsim2.tmLanguage.json",
);
const grammar = JSON.parse(readFileSync(grammarPath, "utf-8"));

const langConfPath = resolve(
  REPO_ROOT,
  "packages/vscode-extension/language-configuration.json",
);
const langConf = parseJsonc(readFileSync(langConfPath, "utf-8"));
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>オンラインエディター | RailSim2 Support</title>
    <meta property="og:title" content="オンラインエディター" />
    <meta property="og:site_name" content="RailSim II Manual" />
    <meta property="og:description" content="RailSim II プラグインのコードをブラウザ上で編集・プレビューできるオンラインエディターです。" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <style is:global>
      body {
        margin: 0;
        overflow: hidden;
        background: #1e1e1e;
        color: #e0e0e0;
      }
      .editor-container {
        height: calc(100dvh - 48px);
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
        box-sizing: border-box;
      }
      .editor-container > *,
      .editor-container > * > * {
        height: 100%;
      }
      @media (max-width: 1200px) {
        .editor-container {
          padding: 0;
        }
      }
    </style>
  </head>
  <body>
    <EditorBanner />
    <div class="editor-container">
      <OnlineEditor client:only="react" samples={samples} grammar={grammar} langConf={langConf} />
    </div>
  </body>
</html>
