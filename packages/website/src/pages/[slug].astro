---
import HelpLayout from "../layouts/HelpLayout.astro";
import { getHelpPages } from "../lib/vendor";

export function getStaticPaths() {
  return getHelpPages()
    .filter((p) => p.slug !== "index")
    .map((page) => ({
      params: { slug: page.slug },
      props: { title: page.title, body: page.body, description: page.description },
    }));
}

const { title, body, description } = Astro.props;
---

<HelpLayout title={title} description={description} noindex>
  <Fragment set:html={body} />
</HelpLayout>
