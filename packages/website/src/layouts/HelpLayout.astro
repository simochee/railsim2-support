---
import Banner from "../components/Banner.astro";
import SearchDialog from "../components/SearchDialog.astro";
import { getVendorCss } from "../lib/vendor";

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  isTop?: boolean;
}

const { title, description, noindex, isTop } = Astro.props;
const pageTitle = isTop ? `${title} | RailSim2 Support` : `${title} - RailSim II Manual | RailSim2 Support`;
const vendorCss = getVendorCss();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{pageTitle}</title>
    <meta property="og:title" content={title} />
    <meta property="og:site_name" content="RailSim II Manual" />
    <meta property="og:description" content={description ?? "RailSim II プラグイン開発のマニュアルドキュメント"} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    {noindex && <meta name="robots" content="noindex" />}
    <Fragment set:html={`<style>${vendorCss}</style>`} />
    <style is:global>
      body {
        margin: 0;
        padding-bottom: 40px;
      }
      main {
        padding-top: 40px;
      }
    </style>
  </head>
  <body>
    <Banner />
    <main>
      <slot />
    </main>
    <SearchDialog />
  </body>
</html>
