---
import { Icon } from "astro-icon/components";
import BannerShell from "./BannerShell.astro";
---

<BannerShell>
  <Fragment slot="left">
    <span class="banner-badge">UNOFFICIAL</span>
    <span>このページは <a href="https://github.com/aizentranza/railsim2" target="_blank" rel="noopener">RailSim II マニュアル</a>の非公式ミラーです。</span>
  </Fragment>
  <Fragment slot="right">
    <pagefind-modal-trigger data-pf-theme="dark"></pagefind-modal-trigger>
    <a href="/editor">
      <Icon name="tabler:code" /> Online Editor
    </a>
    <a href="https://marketplace.visualstudio.com/items?itemName=simochee.vscode-railsim2-grammar" target="_blank" rel="noopener">
      <Icon name="tabler:brand-vscode" /> VS Code 拡張機能
    </a>
  </Fragment>
</BannerShell>

<style>
  .banner-badge {
    background: #ff8000;
    color: #fff;
    font-weight: bold;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }
</style>
