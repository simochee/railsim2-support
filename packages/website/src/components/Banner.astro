---
import { Icon } from "astro-icon/components";
---

<div class="banner" data-pagefind-ignore="all">
  <div class="banner-inner">
    <span class="banner-left">
      <span class="banner-badge">UNOFFICIAL</span>
      <span>このページは <a href="https://github.com/aizentranza/railsim2" target="_blank" rel="noopener">RailSim II ヘルプドキュメント</a>の非公式ミラーです。</span>
    </span>
    <span class="banner-links">
      <pagefind-modal-trigger data-pf-theme="dark"></pagefind-modal-trigger>
      <a href="https://marketplace.visualstudio.com/items?itemName=simochee.vscode-railsim2-grammar" target="_blank" rel="noopener">
        <Icon name="tabler:brand-vscode" /> VS Code 拡張機能
      </a>
    </span>
  </div>
</div>

<style>
  .banner {
    position: sticky;
    top: 0;
    margin-bottom: 40px;
    z-index: 9999;
    background: #1a1a2e;
    border-bottom: 3px solid #ff8000;
  }

  .banner-inner {
    max-width: 1024px;
    margin: 0 auto;
    padding: 4px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    color: #e0e0e0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    font-size: 13px;
    line-height: 1.5;
  }

  .banner-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .banner-badge {
    background: #ff8000;
    color: #fff;
    font-weight: bold;
    font-size: 11px;
    padding: 2px 8px;
    border-radius: 3px;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .banner-inner a {
    color: #64b5f6;
    text-decoration: underline;
  }

  .banner-inner a:hover {
    color: #90caf9;
    background: transparent;
  }

  .banner-links {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    font-size: 13px;
  }

  .banner-links a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: #90caf9;
    transition: color 0.15s;
  }

  .banner-links a:hover {
    color: #fff;
  }

  .banner-links svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    stroke-width: 1.5;
  }

</style>
