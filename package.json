{
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "build": "pnpm -r build",
        "test": "pnpm -r test",
        "generate": "pnpm --filter @lollipop-onl/railsim2-language-server generate",
        "generate:grammar": "pnpm --filter vscode-railsim2-grammar generate:grammar",
        "docs:build": "vite build --config docs-site/vite.config.ts",
        "docs:dev": "vite --config docs-site/vite.config.ts --open",
        "docs:preview": "vite preview --config docs-site/vite.config.ts",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "fmt": "oxfmt packages/",
        "fmt:check": "oxfmt --check packages/"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    },
    "devDependencies": {
        "@tabler/icons": "^3.41.1",
        "iconv-lite": "^0.7.2",
        "oxfmt": "0.44.0",
        "oxlint": "^1.59.0",
        "postcss-modules": "^6.0.1",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "vite": "^8.0.7"
    }
}
