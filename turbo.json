{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["out/**", "dist/**", "tsconfig.tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "generate": {},
    "generate:grammar": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "package": {
      "dependsOn": ["build"],
      "cache": false
    },
    "publish": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
